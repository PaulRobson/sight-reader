{
	"permissions": {
		"allow": [
			"Bash(npm test:*)",
			"Bash(npx vitest:*)",
			"Bash(npm run lint:*)",
			"Bash(npx biome:*)",
			"Bash(npx tsc:*)",
			"Bash(npm run build:*)",
			"Bash(npx knip:*)",
			"Bash(npx jscpd:*)",
			"Bash(npm run duplicate-code:*)",
			"Bash(npm audit:*)",
			"Bash(npm outdated:*)",
			"Bash(npm ls:*)"
		],
		"deny": [
			"Read(.env)",
			"Read(.env.local)",
			"Read(.env.*.local)",
			"Read(.env.production)",
			"Read(.env.development)",
			"Read(.env.staging)",
			"Read(.env.test)",
			"Read(.env.secrets)"
		]
	}
}
